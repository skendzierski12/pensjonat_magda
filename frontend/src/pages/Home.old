                      {"👤".repeat(Math.min(p.liczba_osob, 4))} {p.liczba_osob} {p.liczba_osob === 1 ? "osoba" : "osoby"}
                    </span>
                  </div>
                  <div className="pokoj-card__arrow">→</div>
                </a>
              ))
            )}
