            <h2 className="section-title section-title--light">
              Pokoje<br /><em>i apartamenty</em>
            </h2>
            <p className="section-desc">
              Komfortowe wnętrza z panoramą Gór Sowich za oknem. 
	      Bliskość szlaków i cisza, która pozwala realnie odciąć się od miasta.              
            </p>
            <a href="/oferta" className="btn-primary btn-primary--sm">Zobacz wszystkie</a>
          </div>

          <div className="pokoje-cards">
            {loading ? (
